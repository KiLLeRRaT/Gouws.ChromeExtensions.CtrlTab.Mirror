{
  "manifest_version": 3,
  "name": "MRU Tab Switcher",
  "version": "1.0",
  "description": "Switch between recently used tabs with a VS Code-style MRU panel (Alt+backtick)",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
